<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="view_stock_valuation_quantity_history" model="ir.ui.view">
        <field name="name">Valuation Report</field>
        <field name="model">stock.quantity.history</field>
        <field name="inherit_id" ref="stock.view_stock_quantity_history" />
        <field name="arch" type="xml">
            <button name="open_at_date" position="attributes">
                <!-- Restoring v12 button name, to differentiate from other buttons -->
                <attribute name="invisible">
                    context.get('active_model') != 'product.product'
                </attribute>
            </button>
            <button name="open_at_date" position="after">
                <button
                    name="open_at_date"
                    string="Retrieve the Inventory Quantities"
                    type="object"
                    class="btn-primary"
                    data-hotkey="q"
                    invisible="context.get('active_model') != 'stock.valuation.layer'"
                />
                <button
                    name="button_export_html"
                    string="View report"
                    type="object"
                    invisible="context.get('active_model') != 'stock.valuation.layer'"
                />
                <button
                    name="button_export_pdf"
                    string="Export PDF"
                    type="object"
                    invisible="context.get('active_model') != 'stock.valuation.layer'"
                />
                <button
                    name="button_export_xlsx"
                    string="Export XLSX"
                    type="object"
                    invisible="context.get('active_model') != 'stock.valuation.layer'"
                />
            </button>
        </field>
    </record>
</odoo>
