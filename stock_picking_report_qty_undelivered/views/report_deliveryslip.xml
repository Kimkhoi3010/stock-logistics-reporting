<odoo>
    <template
        id="report_delivery_document_qty_not_done"
        inherit_id="stock.report_delivery_document"
    >
        <xpath
            expr="//div[@t-if='not (o.backorder_ids and backorders)']/following-sibling::div[1]"
            position="after"
        >
            <t t-if="o.picking_type_id.summary_qty_undelivered">
                <t
                    t-set="cancel_moves"
                    t-value="o.move_ids.filtered(lambda x: x.state == 'done' and (x.product_uom_qty > x.quantity))"
                />
                <t t-if="cancel_moves">
                    <p class="mt-5">
                        <span>Summary of undelivered quantities:</span>
                    </p>
                    <table
                        class="table table-borderless"
                        name="stock_moves_cancel_table"
                        style="table-layout: fixed;"
                    >
                        <thead>
                            <tr>
                                <th name="th_uq_product">
                                    <strong>Product</strong>
                                </th>
                                <th name="th_uq_quantity" class="text-center">
                                    <strong>Quantity</strong>
                                </th>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="cancel_moves" t-as="move">
                                <tr>
                                    <td class="w-auto">
                                        <span t-field="move.product_id" />
                                        <p
                                            t-if="move.description_picking != move.product_id.name and move.description_picking != move.product_id.display_name"
                                        >
                                            <span t-field="move.description_picking" />
                                        </p>
                                    </td>
                                    <td class="text-center w-auto">
                                        <span
                                            t-esc="move.product_uom_qty - move.quantity"
                                            t-options="{'widget': 'float', 'decimal_precision': 'Product Unit of Measure'}"
                                        />
                                        <span t-field="move.product_uom" />
                                    </td>
                                </tr>
                            </t>
                        </tbody>
                    </table>
                </t>
            </t>
        </xpath>
    </template>

    <template
        id="stock_report_delivery_aggregated_move_lines_qty_not_done"
        inherit_id="stock.stock_report_delivery_aggregated_move_lines"
        priority="99"
    >
        <xpath expr="//span[contains(@t-esc, 'qty_ordered')]" position="replace">
            <t
                t-if="aggregated_lines[line]['move'].picking_type_id.summary_qty_undelivered"
            >
                <span
                    t-esc="aggregated_lines[line]['move'].product_uom_qty"
                    t-options="{'widget': 'float', 'decimal_precision': 'Product Unit of Measure'}"
                />
            </t>
            <t t-else="">
                <span
                    t-esc="aggregated_lines[line]['qty_ordered']"
                    t-options="{'widget': 'float', 'decimal_precision': 'Product Unit of Measure'}"
                />
            </t>
        </xpath>
    </template>
</odoo>
